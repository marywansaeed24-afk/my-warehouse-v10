{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "A retail store managed within the application.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the store." },
        "email": { "type": "string", "format": "email", "description": "Primary contact email for the store." },
        "ownerId": { "type": "string", "description": "UID of the owner/creator." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the store was created." },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"], "description": "Operational status." }
      },
      "required": ["name", "email", "ownerId", "createdAt", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended information for a registered user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["owner", "admin", "staff"] },
        "storeId": { "type": "string", "description": "The store this user belongs to." },
        "invitationKey": { "type": "string", "description": "Secret key for staff login." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "storeId", "createdAt"]
    },
    "Movement": {
      "title": "Movement",
      "description": "A record of an inventory movement or transaction.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["sale", "stock_in", "stock_out", "adjustment"] },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "price": { "type": "number" },
        "currency": { "type": "string", "enum": ["IQD", "USD"] },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "storeId": { "type": "string" }
      },
      "required": ["type", "amount", "createdAt", "storeId"]
    },
    "Product": {
      "title": "Product",
      "description": "An item in the store inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string", "enum": ["IQD", "USD"] },
        "unit": { "type": "string" },
        "stock": { "type": "number" },
        "threshold": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "color": { "type": "string" },
        "icon": { "type": "string" },
        "storeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "storeId", "category"]
    },
    "BrokenItem": {
      "title": "Broken Item",
      "description": "Record of a broken item.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "quantity": { "type": "number" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "name", "quantity", "createdAt"]
    },
    "SparePart": {
      "title": "Spare Part",
      "description": "Record of a spare part in inventory.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "quantity": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "name", "quantity", "createdAt"]
    }
  },
  "firestore": {
    "stores/{storeId}": {
      "schema": "Store",
      "description": "Collection of retail stores."
    },
    "stores/{storeId}/products/{productId}": {
      "schema": "Product",
      "description": "Inventory items."
    },
    "stores/{storeId}/brokenItems/{itemId}": {
      "schema": "BrokenItem",
      "description": "Log of broken items."
    },
    "stores/{storeId}/spareParts/{partId}": {
      "schema": "SparePart",
      "description": "Inventory of spare parts."
    },
    "stores/{storeId}/movements/{movementId}": {
      "schema": "Movement",
      "description": "Record of activities within the store."
    },
    "stores/{storeId}/staff/{staffId}": {
      "schema": "UserProfile",
      "description": "Staff members associated with the store."
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and permissions."
    }
  }
}
